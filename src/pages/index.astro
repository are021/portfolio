---
const base = import.meta.env.BASE_URL;

const experience = [
  {
    role: "Freelance Software Developer",
    company: "Self-Employed",
    location: "Remote",
    period: "2024 – Present",
    logo: null,
    points: [
      "Design and ship full-stack web and mobile applications for clients, spanning React/Next.js frontends and Node, Flask, and Spring backends.",
      "Build responsive, database-backed web apps with REST and GraphQL APIs, authentication, and cloud deployment.",
      "Own projects end to end — from scoping and architecture through deployment and ongoing maintenance.",
    ],
  },
  {
    role: "Software Engineer",
    company: "Meta",
    location: "Menlo Park, CA",
    period: "March 2025 – Present",
    logo: "logos/meta.png",
    points: [
      "Developed and optimized audio algorithms for real-time communication, improving low-bitrate call quality and reducing latency at billion-user scale.",
      "Designed and ran large-scale experiments to evaluate audio codec performance across diverse network conditions.",
      "Shipped and scaled audio features for Messenger and WhatsApp, enhancing reliability and performance of apps used by billions.",
    ],
